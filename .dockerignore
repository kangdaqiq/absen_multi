# Environment — jangan pernah masuk image
.env
.env.*
!.env.selfhosted.example

# Git
.git
.gitignore
.gitattributes

# Node modules (di-build ulang saat composer install)
node_modules/

# Storage (di-mount via Docker volume)
storage/app/*
storage/logs/*
!storage/app/.gitignore
!storage/logs/.gitignore

# Cache (di-generate ulang saat start)
bootstrap/cache/*.php
!bootstrap/cache/.gitignore

# Testing
tests/
phpunit.xml
.phpunit.result.cache

# Docs & development files
*.md
!README.md
docs/
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Build artifacts
public/hot
public/storage
