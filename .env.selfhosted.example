APP_NAME="Sistem Absensi"
APP_ENV=production
APP_KEY=
# Cara generate: docker exec -it absen_app php artisan key:generate
APP_DEBUG=false
APP_URL=http://localhost         # ← ganti dengan IP/domain server

# ── Self-Hosted Mode ─────────────────────────────────────────────────────
APP_MODE=self_hosted
LICENSE_KEY=XXXX-XXXX-XXXX-XXXX         # ← isi dengan key dari provider
LICENSE_SERVER_URL=https://absen.kangdaqiq.com   # ← URL app HOSTED milik provider

# ── Database ─────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql                   # ← jangan diubah (internal Docker network)
DB_PORT=3306
DB_DATABASE=absen_sell
DB_USERNAME=absen_user
DB_PASSWORD=ganti_password_aman          # ← wajib diisi
DB_ROOT_PASSWORD=ganti_root_password     # ← wajib diisi

# ── Session & Cache ──────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── WhatsApp API (GOWA — Go WhatsApp) ────────────────────────────────────
# Otomatis terhubung ke container "whatsapp" dalam Docker network yang sama
# Jangan diubah kecuali kamu tahu apa yang dilakukan
WA_API_BASE_URL=http://whatsapp:3000    # ← internal Docker network, jangan diubah
WA_API_USER=admin                       # ← samakan dengan BASIC_AUTH_CREDENTIAL di docker-compose.yml
WA_API_PASS=changeme                    # ← samakan dengan BASIC_AUTH_CREDENTIAL di docker-compose.yml

# ── Mail (opsional) ──────────────────────────────────────────────────────
MAIL_MAILER=log
